clear; clc; close all;

myDaq = daq("ni");

%Digital trigger output
addoutput(myDaq, "myDAQ1", "port0/line0", "Digital");

%Digital input
addinput(myDaq, "myDAQ1", "port0/line1", "Digital");

%Initialize output
write(myDaq, false);

triggerOne = repmat([1 0], 1, 50);

while true

    pause(1);

    write(myDaq, true);

    in = read(myDaq, "OutputFormat", "matrix");
    inputState = in(1);
    disp("Input state: " + inputState);
end

write(myDaq, false);